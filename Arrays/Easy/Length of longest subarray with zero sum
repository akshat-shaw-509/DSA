#include <iostream>
#include <vector>
#include <algorithm>
#include <unordered_map>
using namespace std;
int longestSubarray(vector<int>&arr){
    int n=arr.size();
    int maximum=0,sum=0;
    unordered_map<int,int>mp;
    for(int i=0;i<n;i++){
        sum+=arr[i];
        if(sum==0){
            maximum=i+1;
        }
        else{
            if(mp.find(sum)!=mp.end()){
                maximum=max(maximum,i-mp[sum]);
            } else{
                mp[sum]=i;
            }
        }
    }
    return maximum;
}
int main() {
  int A[] = {9, -3, 3, -1, 6, -5};
  int n = sizeof(A) / sizeof(A[0]);
  vector<int> arr(A, A+n);
  cout << longestSubarray(arr) << endl;
  return 0;
}
