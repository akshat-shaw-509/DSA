#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
vector<int>maxMeeting(vector<int>&start,vector<int>&end){
    vector<pair<int,pair<int,int>>>mp;
    for(int i=0;i<start.size();i++){
        mp.push_back({end[i],{start[i],i+1}});
    }
    sort(mp.begin(),mp.end());
    int lastEnd=-1;
    vector<int>result;
    for(auto& i:mp){
        int e=i.first;
        int s=i.second.first;
        int idx=i.second.second;
        if(s>lastEnd){
            result.push_back(idx);
            lastEnd=e;
        }
    }
    return result;
}
int main() {
    vector<int> start = {1, 3, 0, 5, 8, 5};
    vector<int> end   = {2, 4, 6, 7, 9, 9};
    vector<int> res = maxMeeting(start, end);
    for (int idx : res) cout << idx << " ";
}
