#include <iostream>
#include<vector>
#include<algorithm>
using namespace std;
bool compare(pair<int,int>p1,pair<int,int>p2){
    return p1.second>p2.second;
}
int maxProfit(vector<pair<int,int>>jobs){
    sort(jobs.begin(),jobs.end(),compare);
    int maxDeadline=0;
    for(int i=0;i<jobs.size();i++){
        maxDeadline=max(maxDeadline,jobs[i].first);
    }
    int profit=jobs[0].second;
    int safeDeadline=0;
    for(int i=1;i<jobs.size();i++){
        if(safeDeadline<maxDeadline && jobs[i].first>safeDeadline){
            profit+=jobs[i].second;
            safeDeadline++;
        }
    }
    return profit;
}
int main() {
    vector<pair<int, int>> jobs = {{2, 100},{1, 19},{2, 27},{1, 25},{3, 15}};
    int max_profit = maxProfit(jobs);
    cout << "Maximum profit sequence of jobs: " << max_profit << endl;
    return 0;
}
