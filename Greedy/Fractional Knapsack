#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
bool compare(pair<double,int>a,pair<double,int>b){
    return a.first>b.first;
}
double fractionalKnapsack(vector<int>val,vector<int>wt,int capacity){
    int n=val.size();
    double amnt=0;
    vector<pair<double,int>>r;
    for(int i=0;i<n;i++){
        double ratio=(double)val[i]/wt[i];
        r.push_back({ratio,wt[i]});
    }
    sort(r.begin(),r.end(),compare);
    for(int i=0;i<n;i++){
    if(capacity>=r[i].second){
        capacity-=r[i].second;
        amnt+=r[i].first*r[i].second;
    }
    else{
        amnt+=r[i].first*capacity;
        break;
    }
    }
    return amnt;
}
int main(){
    vector<int>val={60,100,120};
    vector<int>wt={10,20,30};
    int capacity=50;
    cout << fractionalKnapsack(val, wt, capacity);
}
