#include<iostream>
#include<vector>
#include<algorithm>
using namespace std;
int countPlatform(vector<int>arr,vector<int>dep){
    sort(arr.begin(),arr.end());
    sort(dep.begin(),dep.end());
    int platform=1;
    int maxPlatform=1;
    int i=1,j=0;
    int m=arr.size(),n=dep.size();
    while(i<m && j<n){
        if(arr[i]<=dep[j]){
            platform++;
            i++;
        } else{
            platform--;
            j++;
        }
        maxPlatform=max(maxPlatform,platform);
    }
    return maxPlatform;
}
int main() {
    vector<int>arr= {900, 945, 955, 1100, 1500, 1800};
    vector<int>dep = {920, 1200, 1130, 1150, 1900, 2000};
    int n = sizeof(arr) / sizeof(arr[0]);
    cout << "Minimum number of Platforms required " 
         << countPlatform(arr, dep) << endl;
    return 0;
}
